# Variables de entorno del proyecto — copiar a .env y rellenar valores reales
# NUNCA commitear .env (está en .gitignore)

# Configuración Flask
FLASK_SECRET_KEY=cambia-esto-por-un-valor-aleatorio-seguro
FLASK_ENV=development

# Credenciales de portales (si alguno requiere autenticación)
# PLACE_API_KEY=
# CONTRATACION_USER=
# CONTRATACION_PASS=

# TendersTool / AdjudicacionesTIC — NO las usa tenderstool_app (esa app pide
# usuario/password por formulario en cada ejecución y nunca los persiste).
# Solo sirven para scripts puntuales de inspección/verificación manual contra
# el sitio real (ver tenderstool_app/README.md, sección "Si cambia la web").
# TENDERSTOOL_URL=https://www.adjudicacionestic.com/front/login.php
# TENDERSTOOL_USER=
# TENDERSTOOL_PASSWORD=
